        setDefaultCloseOperation(EXIT_ON_CLOSE);
        setLayout(new BorderLayout());

        // 整体左右分栏
        JSplitPane splitMain = new JSplitPane(JSplitPane.HORIZONTAL_SPLIT);
        splitMain.setDividerLocation(220);

        // ========== 左侧面板：目录树 + 操作日志 ==========
        JPanel panelLeft = new JPanel();
        panelLeft.setLayout(new BorderLayout());
        // 目录树
        rootNode = new DefaultMutableTreeNode("根目录");
        treeModel = new DefaultTreeModel(rootNode);
        dirTree = new JTree(treeModel);
        panelLeft.add(new JScrollPane(dirTree), BorderLayout.CENTER);
        // 操作信息日志
        txtOpLog = new JTextArea();
        txtOpLog.setEditable(false);
        JPanel panelLog = new JPanel(new BorderLayout());
        panelLog.add(new JLabel("操作信息"), BorderLayout.NORTH);
        panelLog.add(new JScrollPane(txtOpLog), BorderLayout.CENTER);
        panelLog.setPreferredSize(new Dimension(200, 220));
        panelLeft.add(panelLog, BorderLayout.SOUTH);
        splitMain.setLeftComponent(panelLeft);

        // ========== 右侧大区域 ==========
        JPanel panelRightAll = new JPanel();
        panelRightAll.setLayout(new BorderLayout());

        // 顶部按钮栏
        JPanel panelBtnTop = new JPanel();
        panelBtnTop.setLayout(new FlowLayout(FlowLayout.LEFT, 8, 5));
        JButton btnUp = new JButton("↑上级目录");
        JButton btnRefresh = new JButton("刷新");
        JButton btnNewFile = new JButton("新建文件");
        JButton btnNewDir = new JButton("新建文件夹");
        JButton btnDel = new JButton("删除");
        JButton btnRename = new JButton("重命名");
        JButton btnCopy = new JButton("复制");
        JButton btnPaste = new JButton("粘贴");
        panelBtnTop.add(btnUp);
        panelBtnTop.add(btnRefresh);
        panelBtnTop.add(btnNewFile);
        panelBtnTop.add(btnNewDir);
        panelBtnTop.add(btnDel);
        panelBtnTop.add(btnRename);
        panelBtnTop.add(btnCopy);
        panelBtnTop.add(btnPaste);
        panelRightAll.add(panelBtnTop, BorderLayout.NORTH);

        // 当前路径栏
        labelPath = new JLabel("/");
        panelRightAll.add(labelPath, BorderLayout.CENTER);

        // 文件表格
        String[] tableHeader = {"名称", "类型", "大小(字节)", "起始块"};
        tableModel = new DefaultTableModel(tableHeader, 0) {
            @Override
            public boolean isCellEditable(int row, int column) {
                return false;
            }
        };
        fileTable = new JTable(tableModel);
        fileTable.setRowHeight(24);
        panelRightAll.add(new JScrollPane(fileTable), BorderLayout.CENTER);

        // 右下分栏：磁盘图 + 底部按钮
        JSplitPane splitBottom = new JSplitPane(JSplitPane.HORIZONTAL_SPLIT);
        splitBottom.setDividerLocation(700);
        // 磁盘块视图
        JPanel panelDiskWrap = new JPanel(new BorderLayout());
        panelDiskWrap.add(new JLabel("磁盘块使用图"), BorderLayout.NORTH);
        panelDiskBlock = new JPanel();
        panelDiskWrap.add(panelDiskBlock, BorderLayout.CENTER);
        // 底部按钮
        JPanel panelBottomBtn = new JPanel();
        panelBottomBtn.setLayout(new FlowLayout());
        JButton btnViewFAT = new JButton("查看FAT表");
        JButton btnFormat = new JButton("格式化");
        panelBottomBtn.add(btnViewFAT);
        panelBottomBtn.add(btnFormat);
        panelDiskWrap.add(panelBottomBtn, BorderLayout.SOUTH);
        splitBottom.setRightComponent(panelDiskWrap);
        panelRightAll.add(splitBottom, BorderLayout.SOUTH);

        splitMain.setRightComponent(panelRightAll);
        add(splitMain, BorderLayout.CENTER);

        // ========== 按钮绑定事件 ==========
        // 上级目录
        btnUp.addActionListener(e -> {
            String res = cdUp();
            txtOpLog.append(res + "\n");
            refreshAll();
        });
        // 刷新
        btnRefresh.addActionListener(e -> refreshAll());
        // 新建文件
        btnNewFile.addActionListener(e -> {
            String name = JOptionPane.showInputDialog("输入文件名（如test.txt）");
            if (name == null || name.isBlank()) return;
            String res = createFile(name);
            txtOpLog.append(res + "\n");
            refreshAll();
        });
        // 新建文件夹
        btnNewDir.addActionListener(e -> {
            String name = JOptionPane.showInputDialog("输入文件夹名称");
            if (name == null || name.isBlank()) return;
            String res = mkdir(name);
            txtOpLog.append(res + "\n");
            refreshAll();
        });
        // 删除
        btnDel.addActionListener(e -> {
            int row = fileTable.getSelectedRow();
            if (row == -1) {
                txtOpLog.append("请先选中表格中的项目\n");
                return;
            }
            String name = tableModel.getValueAt(row, 0).toString();
            String res = deleteItem(name);
            txtOpLog.append(res + "\n");
            refreshAll();
        });
        // 重命名
        btnRename.addActionListener(e -> {
            int row = fileTable.getSelectedRow();
            if (row == -1) {
                txtOpLog.append("请先选中表格中的项目\n");
                return;
            }
            String old = tableModel.getValueAt(row, 0).toString();
            String newName = JOptionPane.showInputDialog("输入新名称", old);
            if (newName == null || newName.isBlank()) return;
            String res = renameItem(old, newName);
            txtOpLog.append(res + "\n");
            refreshAll();
        });
        // 复制
        btnCopy.addActionListener(e -> {
            int row = fileTable.getSelectedRow();
            if (row == -1) {
                txtOpLog.append("请先选中表格中的文件\n");
                return;
            }
            String name = tableModel.getValueAt(row, 0).toString();
            String res = copyItem(name);
            txtOpLog.append(res + "\n");
        });
        // 粘贴
        btnPaste.addActionListener(e -> {
            String res = pasteItem();
            txtOpLog.append(res + "\n");
            refreshAll();
        });
        // 格式化
        btnFormat.addActionListener(e -> {
            int opt = JOptionPane.showConfirmDialog(null, "确定格式化？所有数据将清空！", "警告", JOptionPane.YES_NO_OPTION);
            if (opt == JOptionPane.YES_OPTION) {
                String res = formatDisk();
                txtOpLog.append(res + "\n");
                refreshAll();
            }
        });
        // 查看FAT表
        btnViewFAT.addActionListener(e -> {
            StringBuilder sb = new StringBuilder("FAT分配表：\n");
            for (int i = 0; i < BLOCK_TOTAL; i++) {
                sb.append("块").append(i).append(" : ").append(fat[i]).append("\t");
                if ((i + 1) % 16 == 0) sb.append("\n");
            }
            JTextArea ta = new JTextArea(sb.toString());
            ta.setEditable(false);
            JOptionPane.showMessageDialog(null, new JScrollPane(ta), "FAT表", JOptionPane.PLAIN_MESSAGE);
        });
        // 目录树双击进入文件夹
        dirTree.addTreeSelectionListener(event -> {
            DefaultMutableTreeNode sel = (DefaultMutableTreeNode) dirTree.getLastSelectedPathComponent();
            if (sel == null || sel == rootNode) return;
            String dirName = sel.getUserObject().toString();
            String res = cdIn(dirName);
            txtOpLog.append(res + "\n");
            refreshAll();
        });
    }

    // 进入目录
    private String cdIn(String dirName) {
        DirEntry target = findEntry(dirName, true);
        if (target == null) return "错误：文件夹不存在";
        pathStack.add(dirName);
        return "进入文件夹：" + dirName;
    }

    // 返回上级
    private String cdUp() {
        if (pathStack.isEmpty()) return "提示：已在根目录，无法返回";
        pathStack.remove(pathStack.size() - 1);
        return "返回上级目录";
    }

    public static void main(String[] args) {
        SwingUtilities.invokeLater(() -> new FATFileSystemGUI().setVisible(true));
    }
}
